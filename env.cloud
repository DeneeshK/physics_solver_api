# ─────────────────────────────────────────────────────────────────────────────
# .env for CLOUD (Groq) operation
# To use: rename this file to ".env" and put your real Groq key below.
# Note: subject to Groq free-tier ~6000 TPM limit. For bulk testing use .env.local.
# ─────────────────────────────────────────────────────────────────────────────

# Leave LLM_BASE_URL blank/unset → the solver uses Groq.
# (Do not set it. Its absence is what selects the cloud path.)

# Your Groq API key:
GROQ_API_KEY=your_groq_api_key_here

# Groq model strings (REQUIRED in cloud mode, because the code's built-in
# defaults now point at the local model name):
MODEL_FAST=llama-3.1-8b-instant
MODEL_SMART=llama-3.3-70b-versatile

# Optional: use the 70B model for Stage 2 selection if the 8B struggles on
# chained problems. Comment out to use MODEL_FAST for Stage 2.
# STAGE2_MODEL=llama-3.3-70b-versatile

STAGE2_BATCH_MODE=auto
ENABLE_CHROMA_LANDING=auto
