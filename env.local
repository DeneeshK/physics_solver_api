# ─────────────────────────────────────────────────────────────────────────────
# .env for LOCAL (Ollama) operation — RTX 3050 8GB
# To use: rename this file to ".env" in your solver directory.
# Prereq: run setup_local_llm.sh first (it creates the "physics-solver-llm" model).
# ─────────────────────────────────────────────────────────────────────────────

# Point the solver at the local Ollama server (OpenAI-compatible endpoint).
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama

# Use the single tuned local model for all stages (loaded once, no reload churn).
MODEL_FAST=physics-solver-llm
MODEL_SMART=physics-solver-llm
STAGE2_MODEL=physics-solver-llm

# Stage 2 batching: keep the default. Per-item calls for multi-item rounds.
STAGE2_BATCH_MODE=auto

# ChromaDB landing: use the index if present.
ENABLE_CHROMA_LANDING=auto
=
# GROQ_API_KEY is not needed in local mode (left blank intentionally).
GROQ_API_KEY
